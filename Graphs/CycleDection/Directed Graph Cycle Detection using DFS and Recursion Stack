#include<bits/stdc++.h>
using namespace std;

bool dfs(int node,
         vector<bool> &recStack,
         vector<bool> &visited,
         vector<vector<int>> &adj)
{
    // Node already in current DFS path
    if(recStack[node])
        return true;

    // Node already processed
    if(visited[node])
        return false;

    visited[node] = true;
    recStack[node] = true;

    for(int nei : adj[node])
    {
        if(dfs(nei, recStack, visited, adj))
        {
            return true;
        }
    }

    // Remove from current DFS path
    recStack[node] = false;

    return false;
}

int main()
{
    int v, e;
    cin >> v >> e;

    vector<vector<int>> adj(v);

    for(int i = 0; i < e; i++)
    {
        int u, vv;
        cin >> u >> vv;

        adj[u].push_back(vv);
    }

    // Print graph
    cout << "Adjacency List:\n";

    for(int i = 0; i < v; i++)
    {
        cout << i << " -> ";

        for(int nei : adj[i])
        {
            cout << nei << " ";
        }

        cout << "\n";
    }

    vector<bool> visited(v, false);
    vector<bool> recStack(v, false);

    bool isCycle = false;

    // Check all components
    for(int i = 0; i < v; i++)
    {
        if(!visited[i])
        {
            if(dfs(i, recStack, visited, adj))
            {
                isCycle = true;
                break;
            }
        }
    }

    if(isCycle)
    {
        cout << "Cycle Found";
    }
    else
    {
        cout << "Cycle Not Found";
    }

    return 0;
}
