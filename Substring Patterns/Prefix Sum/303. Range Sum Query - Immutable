class NumArray {
public:
    vector<int>prefix;
    NumArray(vector<int>& nums) {
        prefix.push_back(0);

        for(int i:nums){
            prefix.push_back(prefix.back() + i);
        }
    }
    
    int sumRange(int left, int right) {

            return prefix[right+1] - prefix[left];
    }
};
